{
  "name": "jwe3-cohabitation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync-dinodex": "tsx scripts/sync-csv-from-dinodex.ts",
    "import-data": "npm run sync-dinodex && tsx scripts/import-spreadsheet.ts",
    "fetch-images": "tsx scripts/fetch-images.ts",
    "setup": "npm run import-data && npm run fetch-images",
    "dev": "npm run import-data && next dev",
    "build": "npm run import-data && next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "csv-parse": "^7.0.1",
    "csv-stringify": "^6.8.1",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
